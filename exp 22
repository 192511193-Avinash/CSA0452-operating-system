#include <stdio.h>

int main() {
    int blockSize[5] = {100,500,200,300,600};
    int processSize[4] = {212,417,112,426};
    int allocation[4];
    int i,j,best;

    for(i=0;i<4;i++)
        allocation[i]=-1;

    for(i=0;i<4;i++) {
        best=-1;

        for(j=0;j<5;j++) {
            if(blockSize[j]>=processSize[i]) {
                if(best==-1 || blockSize[j]<blockSize[best])
                    best=j;
            }
        }

        if(best!=-1) {
            allocation[i]=best;
            blockSize[best]-=processSize[i];
        }
    }

    for(i=0;i<4;i++)
        printf("Process %d allocated to block %d\n",i+1,allocation[i]+1);

    return 0;
}
