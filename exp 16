#include <stdio.h>

struct emp {
    int id;
    char name[20];
};

int main() {
    FILE *fp;
    struct emp e;

    fp = fopen("emp.dat", "wb+");

    printf("Enter ID and Name: ");
    scanf("%d %s", &e.id, e.name);

    fwrite(&e, sizeof(e), 1, fp);

    rewind(fp);

    fread(&e, sizeof(e), 1, fp);
    printf("Employee ID: %d Name: %s\n", e.id, e.name);

    fclose(fp);
    return 0;
}
