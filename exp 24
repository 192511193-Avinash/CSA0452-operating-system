#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char buffer[20];

    fd = open("sample.txt", O_CREAT | O_RDWR, 0644);

    write(fd, "Operating System", 16);

    lseek(fd, 0, SEEK_SET);

    read(fd, buffer, 16);

    buffer[16] = '\0';

    printf("File Content: %s\n", buffer);

    close(fd);

    return 0;
}
